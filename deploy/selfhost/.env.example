# Local-development example values. They are intentionally fake placeholders.
# SECURITY: change POSTGRES_PASSWORD before deploying to any non-local environment.
POSTGRES_DB=zerolink_selfhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=local-dev-postgres-password

# Garage (S3-compatible object storage) — only used with --profile storage.
# SECURITY: replace these placeholders before deploying to any non-local environment.
GARAGE_RPC_SECRET=deadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeef
GARAGE_ADMIN_TOKEN=local-dev-garage-admin-token
GARAGE_S3_ACCESS_KEY_ID=GK000000000000000000000000
GARAGE_S3_SECRET_ACCESS_KEY=feedfacefeedfacefeedfacefeedfacefeedfacefeedfacefeedfacefeedface
# Override when consuming images published from a fork or org mirror.
ZEROLINK_IMAGE_REPOSITORY=ghcr.io/yclgkd
# Pin to a released GHCR image tag such as 0.3.0 when needed.
ZEROLINK_IMAGE_TAG=latest

# Application environment: development | production.
SELFHOST_API_APP_ENV=development
SELFHOST_API_BIND_ADDR=:8788
SELFHOST_API_LOG_LEVEL=info
# WebAuthn Relying Party — must match the exact hostname users access in their browser.
# SECURITY: set RP_ID to your actual public domain (e.g., example.com) and RP_ORIGIN to
# the full origin (e.g., https://example.com) in production. Non-localhost WebAuthn
# requires HTTPS; plain HTTP works only on localhost during local development.
SELFHOST_API_RP_ID=localhost
SELFHOST_API_RP_ORIGIN=http://localhost:8080
SELFHOST_API_DATABASE_URL=postgres://postgres:local-dev-postgres-password@db:5432/zerolink_selfhost?sslmode=disable
# Connection pool settings — defaults work for most single-node deployments.
SELFHOST_API_DB_MAX_CONNS=8
SELFHOST_API_DB_MIN_CONNS=0
SELFHOST_API_DB_CONNECT_TIMEOUT=5s
SELFHOST_API_DB_HEALTH_TIMEOUT=2s
# HTTP server timeouts.
SELFHOST_API_HTTP_READ_TIMEOUT=10s
SELFHOST_API_HTTP_READ_HEADER_TIMEOUT=5s
SELFHOST_API_HTTP_WRITE_TIMEOUT=15s
SELFHOST_API_HTTP_IDLE_TIMEOUT=1m
SELFHOST_API_HTTP_SHUTDOWN_TIMEOUT=10s
# File upload settings.
# Use "s3" for object-storage-backed file uploads, or "inline" for text-only mode.
SELFHOST_API_FILE_STORAGE_BACKEND=s3
# Maximum file size per upload (bytes). Default: 512 MiB.
SELFHOST_API_FILE_MAX_BYTES=536870912
# Legacy inline compatibility threshold (~2 MiB); retained for policy/body-limit alignment and
# does not change the new file-upload path.
SELFHOST_API_FILE_MULTIPART_THRESHOLD_BYTES=2080760
# Size of each multipart chunk (bytes). Default: 4 MiB.
SELFHOST_API_FILE_CHUNK_SIZE_BYTES=4194304
SELFHOST_API_FILE_MAX_CHUNKS=128
SELFHOST_API_FILE_MULTIPART_SUPPORTED=true
# S3-compatible object storage — connects to Garage when using --profile storage,
# or point to any S3-compatible provider (AWS S3, Cloudflare R2, MinIO, etc.).
SELFHOST_API_S3_ENDPOINT=garage:3900
# Optional: set this when the browser can reach S3 directly (e.g., public AWS S3 or R2).
# When unset, file uploads/downloads are proxied through the API server.
# SELFHOST_API_S3_PUBLIC_ENDPOINT=
SELFHOST_API_S3_ACCESS_KEY=GK000000000000000000000000
SELFHOST_API_S3_SECRET_KEY=feedfacefeedfacefeedfacefeedfacefeedfacefeedfacefeedfacefeedface
SELFHOST_API_S3_BUCKET=zerolink-files
# Set to true when your S3 endpoint uses HTTPS.
SELFHOST_API_S3_USE_SSL=false
# Optional: set the region for your S3-compatible provider (e.g., us-east-1, auto for R2).
# SELFHOST_API_S3_REGION=
