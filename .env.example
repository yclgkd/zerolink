# ZeroLink 环境变量模板 / Environment Variables Template
# 复制此文件为 .env 并填入实际值 / Copy to .env and fill in actual values
# 注意：.env 文件不会被提交到 git / Note: .env file is git-ignored

# ============================================================
# Cloudflare Worker 运行时变量
# 通过 wrangler deploy --var 传入，不存储在代码中
# ============================================================

# WebAuthn Relying Party ID（你的域名，不含 https://）
# 例如: zerolink.example.com 或 your-worker.username.workers.dev
RP_ID=

# WebAuthn Origin（完整 URL，含 https://）
# 例如: https://zerolink.example.com
RP_ORIGIN=

# ============================================================
# Manifest 签名（可选，用于可验证发布）
# 生成方法见 docs/DEPLOYMENT.md § Manifest 签名
# ============================================================

# Ed25519 私钥（base64 编码）
# 生成命令: openssl genpkey -algorithm ed25519 -out keys/manifest-signing.pem
# 转换命令: base64 -i keys/manifest-signing.pem | tr -d '\n'
MANIFEST_SIGNING_KEY=

# ============================================================
# Cloudflare API（CI/CD 部署用）
# 在 Cloudflare Dashboard → My Profile → API Tokens 创建
# ============================================================

# Cloudflare API Token（需有 Worker + Pages + KV 权限）
CLOUDFLARE_API_TOKEN=

# Cloudflare 账号 ID（在 Dashboard 右侧边栏可找到）
CLOUDFLARE_ACCOUNT_ID=
