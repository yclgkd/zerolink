{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "paths": {
      "@/*": ["./src/*"],
      "@zerolink/shared": ["../shared/src"],
      "@zerolink/shared/*": ["../shared/src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.d.ts", "playwright*.ts", "vite.config.ts"],
  "exclude": ["node_modules", "dist"]
}
