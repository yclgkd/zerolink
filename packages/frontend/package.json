{
  "name": "@zerolink/frontend",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:verification": "tsc && VITE_RELEASE_VERIFICATION_REQUIRED=true vite build --outDir dist-verification",
    "build:e2e": "vite build",
    "build:verification:e2e": "VITE_RELEASE_VERIFICATION_REQUIRED=true vite build --config vite.config.e2e-verification.ts --outDir dist-verification",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "pnpm test:e2e:ui-smoke && pnpm test:e2e:realtime && pnpm test:e2e:release-verification",
    "test:e2e:ui-smoke": "playwright test -c playwright.config.ts",
    "test:e2e:mock": "pnpm test:e2e:ui-smoke",
    "test:e2e:realtime": "playwright test -c playwright.realtime.config.ts",
    "test:e2e:release-verification": "playwright test -c playwright.verification.config.ts",
    "test:e2e:verification": "pnpm test:e2e:release-verification",
    "test:e2e:smoke": "playwright test -c playwright.smoke.config.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.playwright.json && tsc --noEmit -p e2e/tsconfig.json",
    "typecheck:e2e:support": "tsc --noEmit -p e2e/tsconfig.json"
  },
  "dependencies": {
    "@fontsource-variable/sora": "^5.2.8",
    "@github/webauthn-json": "^2.1.1",
    "@noble/ed25519": "^3.0.0",
    "@noble/hashes": "^2.0.1",
    "@radix-ui/react-slot": "^1.2.4",
    "@zerolink/shared": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^25.8.18",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.575.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.8",
    "react-router-dom": "^7.17.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.1.3",
    "@vitest/ui": "^4.1.3",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^27.0.0",
    "msw": "^2.12.10",
    "tailwindcss": "^4.2.1",
    "vite": "^7.3.5",
    "vitest": "^4.1.3"
  }
}
